meta {
  name: chat-image-base64
  type: http
  seq: 11
}

post {
  url: http://{{MY_PHONE}}:8080/v1/chat/completions
  body: json
  auth: none
}

body:json {
  {
    "model": "Gemma-4-E2B-it",
    "messages": [
      {
        "role": "user",
        "content": [
          {
            "type": "text",
            "text": "What is in this image?"
          },
          {
            "type": "image_url",
            "image_url": {
              "url": "data:image/jpeg;base64,"
            }
          }
        ]
      }
    ]
  }
}

tests {
  test("should return success", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return message 'white' 'cat' 'yellow' 'gold' 'eyes'", function () {
    const body = res.getBody();

    console.log("RAW:", body.choices[0].message.content);

    expect(body).to.have.property("choices");
    expect(body.choices[0]).to.have.property("message");
    expect(body.choices[0].message).to.have.property("content");
    expect(body.choices[0].message.content).to.contain("white");
    expect(body.choices[0].message.content).to.contain("cat");
    expect(body.choices[0].message.content).to.contain("yellow");
    expect(body.choices[0].message.content).to.contain("gold");
    expect(body.choices[0].message.content).to.contain("eyes");
  });

}
