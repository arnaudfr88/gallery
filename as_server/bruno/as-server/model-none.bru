meta {
  name: model-none
  type: http
  seq: 2
}

post {
  url: http://{{MY_PHONE}}:8080/v1/chat/completions
  body: json
  auth: none
}

body:json {
  {
    "model": "gpt-5.4",
    "messages": []
  }
}

tests {
  test("should return not found", function () {
    expect(res.getStatus()).to.equal(404);
  });

  test("should return message 'launch'", function () {
    const body = res.getBody();

    expect(body).to.have.property("error");
    expect(body.error).to.have.property("message");
    expect(body.error.message).to.contain("not found or not initialized");
  });

}
